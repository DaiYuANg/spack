      "targets": [
        {
          "expr": "sum(rate(spack_asset_cache_hits_total{instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum(rate(spack_asset_cache_hits_total{instance=~\"$instance\"}[$__rate_interval])) + sum(rate(spack_asset_cache_misses_total{instance=~\"$instance\"}[$__rate_interval])), 1)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
